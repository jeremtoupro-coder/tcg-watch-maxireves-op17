{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "tcg-watch-one-piece",
  "main": "src/index.ts",
  "compatibility_date": "2026-06-27",
  "workers_dev": true,
  "vars": {
    "AUDIT_MODE": "true",
    "ALLOW_PUBLIC_AUDIT": "false",
    "WRITE_STATE": "false",
    "DISCORD_MODE": "dry-run"
  }
}
